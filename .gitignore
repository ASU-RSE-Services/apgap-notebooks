# Default-deny: nothing is tracked unless explicitly allowed below.
*

# Allow this .gitignore itself
!.gitignore

# Allow the repo README
!README.md

# Allow the notebooks/ directory and the deliverable notebooks
!notebooks/
notebooks/*
!notebooks/01-getting-started.ipynb
!notebooks/02-read-your-data.ipynb
!notebooks/03-launch-a-pipeline.ipynb
!notebooks/04-download-from-public-repos.ipynb
!notebooks/05-reference.ipynb
!notebooks/06-launch-tostadas.ipynb
