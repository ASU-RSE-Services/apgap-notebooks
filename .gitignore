# Default-deny: nothing is tracked unless explicitly allowed below.
# Protects against accidentally committing scoping docs, comms drafts,
# Claude memory, runtime artifacts, backup folders, .tmp files, and
# anything else that lives in the project tree but isn't part of the
# apgap-notebooks deliverable.
*

# Allow this .gitignore itself
!.gitignore

# Allow the repo README
!README.md

# Allow the notebooks/ directory and the five Phase 1 deliverables
!notebooks/
notebooks/*
!notebooks/01-getting-started.ipynb
!notebooks/02-read-your-data.ipynb
!notebooks/03-launch-a-pipeline.ipynb
!notebooks/04-download-from-public-repos.ipynb
!notebooks/05-reference.ipynb
